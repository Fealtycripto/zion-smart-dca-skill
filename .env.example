# Environment variables — copy this to .env and fill in your keys
# Never commit .env to git!

# CoinMarketCap API Key (required)
# Get yours free at: https://pro.coinmarketcap.com/login
CMC_API_KEY=your_cmc_api_key_here

# BNB Chain RPC (for BNB AI Agent SDK)
BNB_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Weekly DCA budget in USD
WEEKLY_BUDGET_USD=100

# Optional: custom thresholds
RSI_BUILDUP_THRESHOLD=35
FG_EXTREME_FEAR=25
FG_EXTREME_GREED=75
